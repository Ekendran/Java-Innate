import java.util.Scanner;

public class EvenOddIndexSum {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        // Ask user for array size
        System.out.print("Enter the size of the array: ");
        int n = sc.nextInt();

        int[] arr = new int[n];

        // Input array elements
        System.out.println("Enter " + n + " integers:");
        for (int i = 0; i < n; i++) {
            arr[i] = sc.nextInt();
        }

        int evenSum = 0;
        int oddSum = 0;

        // Calculate sums based on index
        for (int i = 0; i < n; i++) {
            if (i % 2 == 0) {
                evenSum += arr[i]; // index is even
            } else {
                oddSum += arr[i];  // index is odd
            }
        }

        int result = evenSum - oddSum;

        System.out.println("Sum of even indices: " + evenSum);
        System.out.println("Sum of odd indices: " + oddSum);
        System.out.println("Difference (even - odd): " + result);

        sc.close();
    }
}
