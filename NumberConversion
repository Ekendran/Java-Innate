import java.util.Arrays;
import java.util.Scanner;
public class NumberConversion {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        int originalInt = 0;
        System.out.print("Enter an integer: ");
        if (scanner.hasNextInt()) {
            originalInt = scanner.nextInt();
        } else {
            System.out.println("Error: That's not a valid integer!");
            scanner.close();
            return; // Exit the program
        }
        System.out.println("\n--- Processing Input ---");
        System.out.println("Original int: " + originalInt);
        String intToString = convertToString(originalInt);
        System.out.println("Converted to String: \"" + intToString + "\"");
        int stringToInt = convertToInt(intToString);
        System.out.println("Converted back to int: " + stringToInt);
        int[] digitArray = convertToDigitArray(originalInt);
        System.out.print("Converted int to digit array: ");
        System.out.println(Arrays.toString(digitArray));
    
        scanner.close();
    }
    public static String convertToString(int number) {
        if (number == 0) return "0";
        StringBuilder sb = new StringBuilder();
        boolean isNegative = number < 0;
        long num = Math.abs((long) number); 
        while (num > 0) {
            char digit = (char) ('0' + (num % 10)); 
            sb.append(digit);
            num /= 10; 
        }
        if (isNegative) {
            sb.append("-");
        }
        return sb.reverse().toString(); 
    }
    public static int convertToInt(String str) {
        if (str == null || str.length() == 0) {
            throw new NumberFormatException("Empty string");
        }
        int result = 0;
        int i = 0;
        boolean isNegative = false;
        if (str.charAt(0) == '-') {
            isNegative = true;
            i++;
        } else if (str.charAt(0) == '+') {
            i++;
        }
        for (; i < str.length(); i++) {
            char c = str.charAt(i);
            if (c < '0' || c > '9') { 
                throw new NumberFormatException("Invalid character: " + c);
            }
            int digit = c - '0'; 
            result = result * 10 + digit;
        }
        return isNegative ? -result : result;
    }
    public static int[] convertToDigitArray(int number) {
        if (number == 0) {
            return new int[]{0};
        }
        int temp = Math.abs(number);
        int length = 0;
        while (temp > 0) {
            length++;
            temp /= 10;
        }
        int[] digits = new int[length];
        temp = Math.abs(number);
        for (int i = length - 1; i >= 0; i--) {
            digits[i] = temp % 10;
            temp /= 10;
        }
        return digits;
    }
}
